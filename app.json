{
  "expo": {
    "name": "FamilyApp",
    "slug": "FamilyApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FamilyApp to access your photos for profile pictures.",
          "cameraPermission": "Allow FamilyApp to use your camera for profile pictures."
        }
      ]
    ]
  }
}
